@model mvc2025TermProject.Models.ImageReviewViewModel

@{
    ViewData["Title"] = "Review Images";
    var currentImage = Model.CurrentImage;
    bool isPending = currentImage?.IsApproved == false;
}

<div class="container my-3 my-md-4">
    <div class="position-relative">
        <div class="auth-accent rounded-top"></div>

        <div class="bg-white border shadow-sm overflow-hidden">

            <!-- Header Section -->
            <div class="d-flex flex-wrap align-items-center justify-content-between p-3 p-md-4 border-bottom">
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    <h3 class="fw-bold mb-0 text-dark">@ViewData["Title"]</h3>
                    <span class="badge @(isPending ? "bg-warning text-dark" : "bg-success")">
                        @(isPending ? "Pending Review" : "Approved")
                    </span>
                </div>

                <a asp-action="Index" asp-route-statusFilter="Pending" class="btn btn-light border shadow-sm">
                    <i class="bi bi-arrow-left me-1"></i> Back to List
                </a>
            </div>

            <!-- Recipe Info Bar -->
            <div class="bg-light border-bottom p-3">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div>
                        <h5 class="mb-0 fw-semibold">@Model.RecipeName</h5>
                        <small class="text-muted">
                            <i class="bi bi-person me-1"></i>Owner: @Model.RecipeOwnerName
                        </small>
                    </div>
                    <div class="text-muted">
                        <i class="bi bi-images me-1"></i>
                        Image @(Model.CurrentImageIndex + 1) of @Model.TotalImages
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <div class="row g-0">

                <!-- Image Preview (Left Side - 8 columns) -->
                <div class="col-lg-8">
                    <div class="p-4">

                        @if (TempData["Success"] != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <i class="bi bi-check-circle me-2"></i>
                                @TempData["Success"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }
                        @if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="bi bi-exclamation-triangle me-2"></i>
                                @TempData["Error"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        <!-- Navigation Controls -->
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <a asp-action="Review"
                               asp-route-id="@Model.RecipeId"
                               asp-route-currentImageIndex="@(Model.CurrentImageIndex - 1)"
                               class="btn btn-outline-secondary @(!Model.HasPreviousImage ? "disabled" : "")">
                                <i class="bi bi-chevron-left"></i> Previous
                            </a>

                            <span class="fw-semibold">
                                @(Model.CurrentImageIndex + 1) / @Model.TotalImages
                            </span>

                            <a asp-action="Review"
                               asp-route-id="@Model.RecipeId"
                               asp-route-currentImageIndex="@(Model.CurrentImageIndex + 1)"
                               class="btn btn-outline-secondary @(!Model.HasNextImage ? "disabled" : "")">
                                Next <i class="bi bi-chevron-right"></i>
                            </a>
                        </div>

                        <!-- Large Image Preview -->
                        <div class="border rounded-3 p-3 bg-light text-center">
                            <img src="@currentImage?.FilePath"
                                 alt="@currentImage?.AltText"
                                 class="img-fluid rounded"
                                 style="max-height: 500px; width: 100%; object-fit: contain;" />
                        </div>

                        <!-- Thumbnail Strip (optional - shows all images) -->
                        @if (Model.AllImageThumbnails != null && Model.AllImageThumbnails.Count > 1)
                        {
                            <div class="mt-3">
                                <div class="d-flex gap-2 flex-wrap">
                                    @for (int i = 0; i < Model.AllImageThumbnails.Count; i++)
                                    {
                                        var thumb = Model.AllImageThumbnails[i];
                                        bool isCurrent = i == Model.CurrentImageIndex;

                                        <a asp-action="Review"
                                           asp-route-id="@Model.RecipeId"
                                           asp-route-currentImageIndex="@i"
                                           class="border rounded @(isCurrent ? "border-primary border-3" : "") p-1"
                                           style="width: 80px; height: 80px; display: block;">
                                            <img src="@thumb.FilePath"
                                                 alt="Thumbnail"
                                                 class="img-fluid rounded"
                                                 style="width: 100%; height: 100%; object-fit: cover;" />
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Information & Actions Panel (Right Side - 4 columns) -->
                <div class="col-lg-4 border-start">
                    <div class="p-4">

                        <h6 class="fw-bold mb-3">Image Information</h6>

                        <!-- Image Details -->
                        <div class="mb-3">
                            <div class="border rounded-3 p-3 mb-2">
                                <div class="small text-muted mb-1">Uploaded By</div>
                                <div class="fw-semibold">
                                    @(currentImage?.UploadedBy?.FirstName ?? "Unknown")
                                    @(currentImage?.UploadedBy?.LastName ?? "")
                                </div>
                            </div>

                            <div class="border rounded-3 p-3 mb-2">
                                <div class="small text-muted mb-1">Upload Date</div>
                                <div>@currentImage?.UploadedDate?.ToString("MMMM d, yyyy h:mm tt")</div>
                            </div>

                            <div class="border rounded-3 p-3 mb-2">
                                <div class="small text-muted mb-1">File Info</div>
                                <div>
                                    @((currentImage?.FileSize ?? 0) / 1024) KB • @currentImage?.FileType?.ToUpper()
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(currentImage?.AltText))
                            {
                                <div class="border rounded-3 p-3 mb-2">
                                    <div class="small text-muted mb-1">Alt Text</div>
                                    <div>@currentImage.AltText</div>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(currentImage?.Description))
                            {
                                <div class="border rounded-3 p-3 mb-2">
                                    <div class="small text-muted mb-1">Description</div>
                                    <div>@currentImage.Description</div>
                                </div>
                            }

                            @if (currentImage?.IsApproved == true)
                            {
                                <div class="border rounded-3 p-3 mb-2">
                                    <div class="small text-muted mb-1">Approved By</div>
                                    <div>
                                        @(currentImage.ApprovedBy?.FirstName ?? "Unknown")
                                        @(currentImage.ApprovedBy?.LastName ?? "")
                                    </div>
                                    <div class="small text-muted mt-1">
                                        on @currentImage.ApprovedDate?.ToString("MMM d, yyyy")
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Main Image Checkbox -->
                        <div class="mb-4">
                            <div class="border rounded-3 p-3 bg-light">
                                <div class="form-check">
                                    @if (currentImage?.IsMainImage == true)
                                    {
                                        <input class="form-check-input" type="checkbox" checked disabled>
                                        <label class="form-check-label fw-semibold">
                                            <i class="bi bi-star-fill text-warning me-1"></i>
                                            Main Image for Recipe
                                        </label>
                                    }
                                    else if (currentImage?.IsApproved == true)
                                    {
                                        <form asp-action="SetMainImage" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@currentImage.Id" />
                                            <input type="hidden" name="recipeId" value="@Model.RecipeId" />
                                            <input type="hidden" name="currentImageIndex" value="@Model.CurrentImageIndex" />
                                            <button type="submit" class="btn btn-sm btn-outline-warning">
                                                <i class="bi bi-star me-1"></i>Set as Main Image
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <small class="text-muted">
                                            <i class="bi bi-info-circle me-1"></i>
                                            Approve image first to set as main
                                        </small>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        @if (isPending)
                        {
                            <h6 class="fw-bold mb-3">Review Actions</h6>

                            <!-- Approve Form -->
                            <form asp-action="Approve" method="post" class="mb-2">
                                <input type="hidden" name="id" value="@currentImage.Id" />
                                <input type="hidden" name="recipeId" value="@Model.RecipeId" />
                                <input type="hidden" name="currentImageIndex" value="@Model.CurrentImageIndex" />
                                <button type="submit" class="btn btn-cb-primary w-100">
                                    <i class="bi bi-check-circle me-1"></i>
                                    Approve Image
                                </button>
                            </form>

                            <!-- Reject Form with Reason -->
                            <div class="border rounded-3 p-3">
                                <form asp-action="Reject" method="post">
                                    <input type="hidden" name="id" value="@currentImage.Id" />
                                    <input type="hidden" name="recipeId" value="@Model.RecipeId" />
                                    <input type="hidden" name="currentImageIndex" value="@Model.CurrentImageIndex" />

                                    <div class="mb-2">
                                        <label class="form-label small fw-semibold">Rejection Reason (Optional)</label>
                                        <textarea name="rejectionReason"
                                              class="form-control form-control-sm"
                                              rows="2"
                                              placeholder="e.g., Inappropriate, poor quality, etc."></textarea>
                                    </div>

                                    <button type="submit" class="btn btn-danger w-100">
                                        <i class="bi bi-x-circle me-1"></i>
                                        Reject Image
                                    </button>
                                </form>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-success small py-2" role="alert">
                                <i class="bi bi-check-circle me-1"></i>
                                This image has been approved.
                            </div>
                        }

                    </div>
                </div>

            </div> <!-- End Row -->

        </div>
    </div>
</div>
