@model mvc2025TermProject.Models.Image

<a asp-controller="ImagesAdmin" asp-action="Details" asp-route-id="@Model.Id"
   class="card border shadow-sm h-100 text-decoration-none image-action-link">

    <!-- Image Preview -->
    <div class="position-relative">
        <img src="@Model.FilePath"
             class="card-img-top h-200"
             alt="@Model.AltText"
             style="object-fit: cover;">

        <!-- Status Badge -->
        @if (Model.IsApproved == true)
        {
            <span class="position-absolute top-0 end-0 badge bg-success m-2">
                <i class="bi bi-check-circle me-1"></i>Approved
            </span>
        }
        else
        {
            <span class="position-absolute top-0 end-0 badge bg-warning text-dark m-2">
                <i class="bi bi-clock me-1"></i>Pending
            </span>
        }

        <!-- Main Image Badge -->
        @if (Model.IsMainImage == true)
        {
            <span class="position-absolute top-0 start-0 badge bg-primary m-2">
                <i class="bi bi-star-fill me-1"></i>Main
            </span>
        }
    </div>

    <div class="card-body">
        <!-- Recipe Name -->
        <h6 class="card-title fw-bold mb-2 text-dark">
            @(Model.Recipe?.Name ?? "Unknown Recipe")
        </h6>

        <!-- Image Details -->
        <div class="small text-muted">
            <div class="mb-1">
                <i class="bi bi-person me-1"></i>
                <strong>By:</strong> @(Model.UploadedBy?.FirstName ?? "Unknown") @(Model.UploadedBy?.LastName ?? "")
            </div>
            <div class="mb-1">
                <i class="bi bi-calendar me-1"></i>
                <strong>Uploaded:</strong> @Model.UploadedDate?.ToString("MMM d, yyyy")
            </div>
            <div>
                <i class="bi bi-file-earmark me-1"></i>
                <strong>Size:</strong> @((Model.FileSize ?? 0) / 1024) KB • @Model.FileType?.ToUpper()
            </div>
        </div>

        <!-- Quick Action Hint -->
        @if (Model.IsApproved == false)
        {
            <div class="mt-3 pt-3 border-top">
                <small class="text-muted">
                    <i class="bi bi-arrow-right-circle me-1"></i>
                    Click to review and approve
                </small>
            </div>
        }
    </div>
</a>