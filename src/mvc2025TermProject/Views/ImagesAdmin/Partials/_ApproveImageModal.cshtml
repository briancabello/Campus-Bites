@model mvc2025TermProject.Models.Image

@{
    var modalId = $"approveModal-{Model.Id}";
}

<div class="modal fade" id="@modalId" tabindex="-1" aria-hidden="true"
     data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-lg shadow-lg overflow-hidden">
            <div class="auth-accent"></div>
            <div class="modal-header bg-light border-0">
                <h5 class="modal-title fw-bold text-dark">Approve Image</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form asp-controller="ImagesAdmin" asp-action="Approve" method="post">
                <div class="modal-body">
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="alert alert-success small py-2 mb-3">
                        <i class="bi bi-check-circle me-1"></i>
                        This will make the image visible to all users and notify the owner.
                    </div>

                    <!-- Recipe Info -->
                    <div class="mb-3">
                        <strong>Recipe:</strong> @Model.Recipe?.Name
                    </div>

                    <div class="mb-3">
                        <strong>Uploaded by:</strong> @Model.UploadedBy?.FirstName @Model.UploadedBy?.LastName
                    </div>

                    <!-- Image Preview -->
                    <div class="mb-3 text-center">
                        <img src="@Model.FilePath"
                             class="img-fluid rounded border h-200"
                             alt="@Model.AltText"
                             style="object-fit: cover;">
                    </div>

                    @if (!string.IsNullOrEmpty(Model.AltText))
                    {
                        <div class="mb-3 text-center">
                            <span class="text-muted small">"@Model.AltText"</span>
                        </div>
                    }

                    <!-- Image Details -->
                    <div class="small text-muted mb-3">
                        <div class="row">
                            <div class="col-6">
                                <i class="bi bi-file-earmark me-1"></i>
                                <strong>Type:</strong> @Model.FileType?.ToUpper()
                            </div>
                            <div class="col-6">
                                <i class="bi bi-hdd me-1"></i>
                                <strong>Size:</strong> @((Model.FileSize ?? 0) / 1024) KB
                            </div>
                        </div>
                    </div>

                    @if (Model.IsMainImage == true)
                    {
                        <div class="alert alert-info py-2 mb-3 small" role="alert">
                            <i class="bi bi-star-fill me-1"></i>
                            <strong>Main Image:</strong> This will be the primary display image for the recipe.
                        </div>
                    }

                    <div class="alert alert-light border small py-2 mb-0">
                        <i class="bi bi-info-circle me-1"></i>
                        <strong>What happens next:</strong>
                        <ul class="mb-0 mt-2 ps-3">
                            <li>Image will be moved to the main images folder</li>
                            <li>Image will be visible to all site visitors</li>
                            <li>Owner will receive an email notification</li>
                        </ul>
                    </div>
                </div>

                <div class="modal-footer border-0 px-4 pb-4 pt-2">
                    <button type="button" class="btn btn-light border shadow-sm" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </button>
                    <button type="submit" class="btn btn-success shadow-sm">
                        <i class="bi bi-check-circle me-1"></i>Approve Image
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>