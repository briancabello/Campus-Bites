@model mvc2025TermProject.Models.ImageAdminIndexViewModel

<div class="p-3 p-md-4 border-bottom bg-white">
    <div class="row g-2">
        <div class="col-12 col-md-auto">
            <a asp-action="Index"
               asp-route-statusFilter="Pending"
               asp-route-sortOrder="@ViewData["CurrentSort"]"
               asp-route-filterCriteria="@ViewData["SearchFilterCriteria"]"
               class="btn @(Model.StatusFilter == "Pending" ? "btn-cb-primary" : "btn-outline-secondary") w-100">
                <i class="bi bi-clock-history me-1"></i>
                Pending
                <span class="badge @(Model.StatusFilter == "Pending" ? "bg-white text-dark" : "bg-secondary") ms-1">
                    @Model.PendingCount
                </span>
            </a>
        </div>
        <div class="col-12 col-md-auto">
            <a asp-action="Index"
               asp-route-statusFilter="Approved"
               asp-route-sortOrder="@ViewData["CurrentSort"]"
               asp-route-filterCriteria="@ViewData["SearchFilterCriteria"]"
               class="btn @(Model.StatusFilter == "Approved" ? "btn-cb-primary" : "btn-outline-secondary") w-100">
                <i class="bi bi-check-circle me-1"></i>
                Approved
                <span class="badge @(Model.StatusFilter == "Approved" ? "bg-white text-dark" : "bg-secondary") ms-1">
                    @Model.ApprovedCount
                </span>
            </a>
        </div>
        <div class="col-12 col-md-auto">
            <a asp-action="Index"
               asp-route-statusFilter="All"
               asp-route-sortOrder="@ViewData["CurrentSort"]"
               asp-route-filterCriteria="@ViewData["SearchFilterCriteria"]"
               class="btn @(Model.StatusFilter == "All" ? "btn-cb-primary" : "btn-outline-secondary") w-100">
                <i class="bi bi-images me-1"></i>
                All Images
                <span class="badge @(Model.StatusFilter == "All" ? "bg-white text-dark" : "bg-secondary") ms-1">
                    @Model.TotalCount
                </span>
            </a>
        </div>
    </div>
</div>
