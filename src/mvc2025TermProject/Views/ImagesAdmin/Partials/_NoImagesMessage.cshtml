@model string

@{
    var statusFilter = Model ?? "All";
}

<div class="text-center py-5">
    <i class="bi bi-images display-1 text-muted"></i>
    <h4 class="text-muted mt-3">
        @if (statusFilter == "Pending")
        {
            <text>No pending images to review</text>
        }
        else if (statusFilter == "Approved")
        {
            <text>No approved images yet</text>
        }
        else
        {
            <text>No images found</text>
        }
    </h4>
    <p class="text-muted">
        @if (statusFilter == "Pending")
        {
            <text>All images have been reviewed! Great job! 🎉</text>
        }
        else if (statusFilter == "Approved")
        {
            <text>Approved images will appear here once you review pending uploads.</text>
        }
        else
        {
            <text>No images have been uploaded to the system yet.</text>
        }
    </p>
</div>