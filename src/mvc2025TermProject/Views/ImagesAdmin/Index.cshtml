@model mvc2025TermProject.Models.ImageAdminViewModel
@{
    ViewData["Title"] = "Review Images";
}

<div class="container my-3 my-md-4">
    <div class="position-relative">
        <div class="auth-accent rounded-top"></div>
        <div class="bg-white border shadow-sm overflow-hidden">

            <!-- Header Section -->
            <div class="p-3 p-md-4 border-bottom">
                <div class="d-none d-md-flex align-items-center justify-content-between mb-1">
                    <h3 class="fw-bold mb-0 text-dark">@ViewData["Title"]</h3>
                    <div class="text-muted fw-medium">
                        <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("dddd, MMMM d, yyyy")
                    </div>
                </div>
                <div class="d-md-none">
                    <h3 class="fw-bold text-dark mb-1">@ViewData["Title"]</h3>
                </div>
            </div>

            <!-- Status Filter Tabs -->
            <partial name="Partials/_ImageStatusFilter" model="Model" />

            <!-- Images Gallery -->
            <div class="p-3 p-md-4">
                @if (Model.Images != null && Model.Images.Any())
                {
                    <div class="row g-3">
                        @foreach (var image in Model.Images)
                        {
                            <div class="col-12 col-md-6 col-lg-4">
                                <partial name="Partials/_ImageReviewCard" model="image" />
                            </div>
                        }
                    </div>
                }
                else
                {
                    <partial name="Partials/_NoImagesMessage" model="Model.StatusFilter" />
                }
            </div>
        </div>
    </div>
</div>

<!-- Include Action Modals -->
@if (Model.Images != null)
{
    foreach (var image in Model.Images.Where(i => i.IsApproved == false))
    {
        <partial name="Partials/_ApproveImageModal" model="image" />
        <partial name="Partials/_RejectImageModal" model="image" />
    }
}